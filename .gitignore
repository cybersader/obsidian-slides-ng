# --- Build output ---
# main.js + styles.css are generated by esbuild from src/. The release
# workflow rebuilds them in CI, so we don't commit them. Canonical source
# lives under src/.
/main.js
/main.js.map
/styles.css
.obsidian/plugins/slides-ng/main.js
.obsidian/plugins/slides-ng/main.js.map
.obsidian/plugins/slides-ng/styles.css
*.map

# Generated assets — reveal.js + theme CSS inlined as string constants by
# scripts/generate-reveal-assets.mjs. Regenerated on every `bun run dev`
# or `bun run build`.
src/render/revealAssets.generated.ts

# Note: .obsidian/plugins/slides-ng/manifest.json IS committed if you want a clean
# install of this repo to "just work" as a vault. Or gitignore it and let the build
# regenerate. Pick one — the brief recommends committing it so cloning gives a
# working vault out of the box.

# --- Dependencies ---
node_modules/
bun.lockb

# --- Obsidian vault state (per-user, not the plugin) ---
.obsidian/workspace*.json
.obsidian/cache
.obsidian-cache/
# Plugin runtime settings — user-specific, regenerated by Obsidian on save.
# Don't ship the dev-vault user's preferences (theme, panel order, etc.).
.obsidian/plugins/slides-ng/data.json
# Debug log written by the plugin when debugLogging:true (v0.10.2+).
slides-ng-debug.log

# Other community plugins installed in this dev vault (Hot Reload, etc.) — don't ship
.obsidian/plugins/hot-reload/
.obsidian/plugins/!(slides-ng)/

# --- Settings local to dev machine ---
.claude/settings.local.json
.claude/scheduled_tasks.lock
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Exported/printed PDFs (testing content — must NEVER reach GitHub) ---
*.pdf

# --- Standalone export artifacts (generated on demand by the plugin) ---
# Both forms: the builder emits a dot-prefixed name, but files can land
# without the dot (Obsidian adapter / manual rename). These can contain
# real deck content — must NEVER reach GitHub.
.slides-ng-export-*.html
slides-ng-export-*.html
# Belt-and-suspenders: ANY root-level .html is a dropped export / debug
# artifact (the plugin's real source is TS — no root .html is ever
# committed). Keeps confidential decks dropped for debugging out of git
# even when renamed (e.g. test-autosize-bug.html).
/*.html

# --- Logs ---
debug.log
*.log

# --- Misc ---
.eslintcache
.cache/
dist/
coverage/

# --- E2E artifacts ---
test-results/

# The e2e-vault folder itself is committed (small fixture so contributors
# can run `bun run e2e` out of the box), but its built-plugin artifacts
# are regenerated by the WDIO onPrepare hook.
e2e-vault/.obsidian/plugins/slides-ng/main.js
e2e-vault/.obsidian/plugins/slides-ng/main.js.map
e2e-vault/.obsidian/plugins/slides-ng/styles.css
e2e-vault/.obsidian/workspace*.json
e2e-vault/.obsidian/cache
