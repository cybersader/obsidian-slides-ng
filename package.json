{
  "name": "obsidian-slides-ng",
  "version": "0.12.3",
  "description": "Markdown slide decks for Obsidian — zero localhost ports, no spawned dev server, reveal.js + Shiki bundled.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "gen:reveal-assets": "bun run scripts/generate-reveal-assets.mjs",
    "predev": "bun run gen:reveal-assets",
    "prebuild": "bun run gen:reveal-assets",
    "dev": "bun run esbuild.config.mjs",
    "dev:reload": "AUTORELOAD=1 bun run esbuild.config.mjs",
    "build": "bun x tsc -noEmit -skipLibCheck && bun run esbuild.config.mjs production",
    "lint": "eslint src",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "e2e": "wdio run wdio.conf.mts",
    "smoke:render": "bun run gen:reveal-assets && bun run scripts/render-example.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "slides",
    "reveal.js",
    "slidev",
    "presentation"
  ],
  "author": "cybersader",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@typescript-eslint/utils": "^8.32.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.17.0",
    "eslint-plugin-obsidianmd": "latest",
    "obsidian": "latest",
    "reveal.js-menu": "2.1.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.32.0",
    "wdio-obsidian-reporter": "^2.0.0",
    "wdio-obsidian-service": "^2.2.0"
  },
  "dependencies": {
    "@slidev/parser": "^51.0.0",
    "marked": "^14.0.0",
    "reveal.js": "^5.1.0",
    "shiki": "^1.24.0",
    "shiki-magic-move": "^0.5.0"
  }
}
